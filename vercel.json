{
  "version": 2,
  "functions": {
    "api/[...path].js": {
      "includeFiles": "{index.html,app.js,site-config.js,styles.css,shiseido-catalog.json,Shiseido_Banner.png,Latency_loader.png,Close.png,Skincare _ SHISEIDO_Images/**}"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path].js"
    },
    {
      "src": "/(.*)",
      "dest": "/api/[...path].js"
    }
  ]
}
